@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<h1 class="admin-title mb-1">Dashboard</h1>
<p class="text-secondary mb-4">Visão geral do conteúdo do site</p>

<div class="row g-3">
    <div class="col-md-4 col-lg-2">
        <div class="admin-card text-center">
            <i class="fas fa-map-location-dot fa-2x mb-2" style="color:#FF5A00;"></i>
            <h2 class="mb-0">@ViewBag.TotalAttractions</h2>
            <small class="text-secondary">Atrações</small>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="admin-card text-center">
            <i class="fas fa-calendar-days fa-2x mb-2" style="color:#FF5A00;"></i>
            <h2 class="mb-0">@ViewBag.TotalEvents</h2>
            <small class="text-secondary">Eventos</small>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="admin-card text-center">
            <i class="fas fa-circle-question fa-2x mb-2" style="color:#FF5A00;"></i>
            <h2 class="mb-0">@ViewBag.TotalFAQs</h2>
            <small class="text-secondary">FAQs</small>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="admin-card text-center">
            <i class="fas fa-compass fa-2x mb-2" style="color:#FF5A00;"></i>
            <h2 class="mb-0">@ViewBag.TotalGuideItems</h2>
            <small class="text-secondary">Itens do Guia</small>
        </div>
    </div>
</div>

<div class="row g-3 mt-4">
    <div class="col-12">
        <div class="admin-card">
            <h5 class="fw-bold mb-3"><i class="fas fa-bolt me-2" style="color:#FF5A00;"></i>Ações Rápidas</h5>
            <div class="d-flex flex-wrap gap-2">
                <a href="/Admin/AttractionForm" class="btn btn-admin-primary"><i class="fas fa-plus me-1"></i> Nova Atração</a>
                <a href="/Admin/EventForm" class="btn btn-outline-dark"><i class="fas fa-plus me-1"></i> Novo Evento</a>
                <a href="/Admin/FAQForm" class="btn btn-outline-dark"><i class="fas fa-plus me-1"></i> Nova FAQ</a>
                <a href="/Admin/GuideItemForm" class="btn btn-outline-dark"><i class="fas fa-plus me-1"></i> Novo Item do Guia</a>
            </div>
        </div>
    </div>
</div>
