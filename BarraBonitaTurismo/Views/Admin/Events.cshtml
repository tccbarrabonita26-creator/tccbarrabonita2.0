@model List<BarraBonitaTurismo.Models.Event>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Eventos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="admin-title mb-1">Eventos</h1>
        <p class="text-secondary mb-0">Gerencie o calendário de eventos da cidade</p>
    </div>
    <a href="/Admin/EventForm" class="btn btn-admin-primary"><i class="fas fa-plus me-1"></i> Novo Evento</a>
</div>

<div class="admin-card p-0">
    <table class="table mb-0 align-middle">
        <thead>
            <tr>
                <th>Título</th>
                <th>Tipo</th>
                <th>Data Início</th>
                <th>Data Fim</th>
                <th>Local</th>
                <th>Destaque</th>
                <th style="width: 140px;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td class="fw-semibold">@e.Title</td>
                    <td><span class="badge bg-secondary">@e.EventType</span></td>
                    <td>@e.StartDate.ToString("dd/MM/yyyy")</td>
                    <td>@(e.EndDate.HasValue ? e.EndDate.Value.ToString("dd/MM/yyyy") : "-")</td>
                    <td class="text-secondary small">@e.Location</td>
                    <td>
                        @if (e.IsFeatured)
                        {
                            <span class="badge bg-success">Sim</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark">Não</span>
                        }
                    </td>
                    <td>
                        <a href="/Admin/EventForm?id=@e.Id" class="btn btn-sm btn-outline-dark"><i class="fas fa-pen"></i></a>
                        <form method="post" action="/Admin/EventDelete" style="display:inline">
                            <input type="hidden" name="id" value="@e.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
