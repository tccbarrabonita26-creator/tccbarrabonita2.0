@model BarraBonitaTurismo.Models.Attraction
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.Id == 0 ? "Nova Atração" : "Editar Atração";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="admin-title mb-0">@(Model.Id == 0 ? "Nova Atração" : "Editar Atração")</h1>
    <a href="/Admin/Attractions" class="btn btn-outline-dark"><i class="fas fa-arrow-left me-1"></i> Voltar</a>
</div>

<div class="admin-card">
    <form method="post" action="/Admin/AttractionForm">
        <input type="hidden" asp-for="Id" />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Nome *</label>
                <input asp-for="Name" class="form-control" required maxlength="200" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Categoria *</label>
                <select asp-for="Category" class="form-select" required>
                    <option value="Náutica">Náutica</option>
                    <option value="Cultura">Cultura</option>
                    <option value="Natureza">Natureza</option>
                    <option value="Lazer">Lazer</option>
                </select>
            </div>

            <div class="col-12">
                <label class="form-label fw-semibold">Descrição *</label>
                <textarea asp-for="Description" class="form-control" rows="5" required></textarea>
            </div>

            <div class="col-md-8">
                <label class="form-label fw-semibold">URL da Imagem</label>
                <input asp-for="ImageUrl" class="form-control" maxlength="500" />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" style="height:46px; border-radius:8px; object-fit:cover;" onerror="this.style.display='none'">
                }
            </div>

            <div class="col-md-8">
                <label class="form-label fw-semibold">Endereço</label>
                <input asp-for="Address" class="form-control" maxlength="300" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Horário de Funcionamento</label>
                <input asp-for="Schedule" class="form-control" maxlength="200" />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Latitude</label>
                <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Longitude</label>
                <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
            </div>

            <div class="col-12">
                <label class="form-label fw-semibold">Curiosidade (Você sabia?)</label>
                <input asp-for="FunFact" class="form-control" maxlength="500" />
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2">
            <a href="/Admin/Attractions" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-admin-primary"><i class="fas fa-save me-1"></i> Salvar</button>
        </div>
    </form>
</div>
