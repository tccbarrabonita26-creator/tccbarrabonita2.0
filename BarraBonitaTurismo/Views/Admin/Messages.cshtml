@model List<BarraBonitaTurismo.Models.ContactMessage>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Mensagens";
}

<h1 class="admin-title mb-1">Mensagens de Contato</h1>
<p class="text-secondary mb-4">Mensagens enviadas pelos visitantes através do formulário de contato</p>

@if (!Model.Any())
{
    <div class="admin-card text-center text-secondary py-5">
        <i class="fas fa-inbox fa-2x mb-3"></i>
        <p class="mb-0">Nenhuma mensagem recebida ainda.</p>
    </div>
}
else
{
    <div class="admin-card p-0">
        <table class="table mb-0 align-middle">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th>Assunto</th>
                    <th>Mensagem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td class="text-secondary small">@m.SentAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-semibold">@m.Name</td>
                        <td>@m.Email</td>
                        <td>@m.Subject</td>
                        <td class="text-secondary small">@(m.Message.Length > 100 ? m.Message.Substring(0, 100) + "..." : m.Message)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
