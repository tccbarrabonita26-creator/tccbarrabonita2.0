@model BarraBonitaTurismo.Models.FAQ
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.Id == 0 ? "Nova Pergunta" : "Editar Pergunta";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="admin-title mb-0">@(Model.Id == 0 ? "Nova Pergunta" : "Editar Pergunta")</h1>
    <a href="/Admin/FAQs" class="btn btn-outline-dark"><i class="fas fa-arrow-left me-1"></i> Voltar</a>
</div>

<div class="admin-card">
    <form method="post" action="/Admin/FAQForm">
        <input type="hidden" asp-for="Id" />

        <div class="row g-3">
            <div class="col-md-10">
                <label class="form-label fw-semibold">Pergunta *</label>
                <input asp-for="Question" class="form-control" required maxlength="500" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Ordem</label>
                <input asp-for="Order" type="number" class="form-control" />
            </div>

            <div class="col-12">
                <label class="form-label fw-semibold">Resposta *</label>
                <textarea asp-for="Answer" class="form-control" rows="5" required></textarea>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-end gap-2">
            <a href="/Admin/FAQs" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-admin-primary"><i class="fas fa-save me-1"></i> Salvar</button>
        </div>
    </form>
</div>
