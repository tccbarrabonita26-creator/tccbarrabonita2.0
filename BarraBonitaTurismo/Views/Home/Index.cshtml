@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using BarraBonitaTurismo.Models
@{
    ViewData["Title"] = "Barra Bonita - Estância Turística | Portal Oficial";
    var cityInfo = ViewBag.CityInfo as CityInfo;
    var upcomingEvents = ViewBag.UpcomingEvents as List<Event>;
    var allAttractions = ViewBag.AllAttractions as List<Attraction>;
    var faqs = ViewBag.FAQs as List<FAQ>;
    var guideItemsByType = ViewBag.GuideItemsByType as Dictionary<string, List<GuideItem>>;

    // Dados das atrações com coordenadas, prontos para o mapa interativo
    var mapMarkers = allAttractions
        .Where(a => a.Latitude.HasValue && a.Longitude.HasValue)
        .Select(a => new
        {
            id = a.Id,
            name = a.Name,
            category = a.Category,
            lat = a.Latitude.Value,
            lng = a.Longitude.Value,
            url = $"/Home/AttractionDetail/{a.Id}"
        });
    var mapMarkersJson = System.Text.Json.JsonSerializer.Serialize(mapMarkers);
}

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom">
    <div class="container">
        <a class="navbar-brand" href="#hero">
            <img src="~/img/Logo Horizontal 2.png" alt="Barra Bonita" style="height: 50px; width: auto;">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link-custom" href="#hero">INÍCIO</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#historia">HISTÓRIA</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#atracoes">ATRAÇÕES</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#mapa">MAPA</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#calendario">CALENDÁRIO</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#hospitalidade">HOSPITALIDADE</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#faq">FAQ</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#contato">CONTATO</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="hero" id="hero"
         style="background-image: url('/img/Banner.png'); background-size: cover; background-position: center;">
    <div class="container text-center">
        <div class="hero-badge">A Pérola do Tietê</div>
        <h1 class="hero-title">
            <small>Boas-vindas à</small>
            <large>Barra Bonita</large>
        </h1>
        <p class="hero-subtitle">
            Descubra a eclusa mais famosa do Brasil e encante-se com a hospitalidade de uma estância turística
            inesquecível.
        </p>
        <a href="#atracoes" class="btn-primary-custom">
            Começar Exploração
            <i class="fas fa-arrow-right"></i>
        </a>
    </div>
    <div class="hero-scroll">
        <div class="d-flex flex-column align-items-center">
            <span class="text-white small fw-bold tracking-wide">Role para descobrir</span>
            <i class="fas fa-chevron-down text-white mt-2 animate-bounce"></i>
        </div>
    </div>
</section>

<!-- History Section -->
<section class="section section-white" id="historia">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="history-image">
                    <img src="https://i0.wp.com/temcidades.com.br/wp-content/uploads/2025/08/WhatsApp-Image-2025-08-26-at-23.58.57.jpeg?resize=768%2C311&ssl=1"
                         class="history-img">
                </div>
            </div>

            <div class="col-lg-6">
                <span class="section-tag">Nossa Herança</span>
                <h2 class="section-title">Um destino forjado pelas águas e pelo tempo</h2>
                <p class="fs-5 text-secondary">
                    @Html.Raw(cityInfo?.History?.Split('\n')[0])
                </p>
                <div class="history-quote">
                    "Aqui o rio é limpo, a história é viva e cada pôr do sol nas águas é uma celebração da natureza."
                </div>
                <div class="stats">
                    <div>
                        <div class="stat-number">1886</div>
                        <div class="stat-label">Fundação Oficial</div>
                    </div>
                    <div>
                        <div class="stat-number">1973</div>
                        <div class="stat-label">Inauguração da Eclusa</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Attractions Section -->
<section class="section section-light" id="atracoes">
    <div class="container">
        <div class="text-center">
            <span class="section-tag">Explore a Cidade</span>
            <h2 class="section-title">Atrações Principais</h2>
            <div class="section-divider"></div>
        </div>

        <!-- Busca -->
        <div class="attractions-search-wrapper">
            <div class="attractions-search-box">
                <i class="fas fa-search"></i>
                <input type="text" id="attractionSearch" placeholder="Buscar atração por nome ou descrição...">
            </div>
        </div>

        <div class="filters-container">
            <button class="filter-btn filter-btn-active" data-filter="all">Todas</button>
            <button class="filter-btn filter-btn-inactive" data-filter="Náutica">Náutica</button>
            <button class="filter-btn filter-btn-inactive" data-filter="Cultura">Cultura</button>
            <button class="filter-btn filter-btn-inactive" data-filter="Natureza">Natureza</button>
            <button class="filter-btn filter-btn-inactive" data-filter="Lazer">Lazer</button>
        </div>

        <p id="noResultsMsg" class="text-center text-secondary" style="display:none; margin-top: 20px;">
            Nenhuma atração encontrada com esses critérios.
        </p>

        <!-- Grupo sempre visível: primeiros 8 cards -->
        <div class="attractions-grid" id="gridPrimary">
            @foreach (var attraction in allAttractions.Take(8))
            {
                <div class="attraction-card" data-category="@attraction.Category" data-id="@attraction.Id"
                     data-name="@attraction.Name.ToLower()" data-desc="@attraction.Description.ToLower()">
                    <img class="attraction-image" src="@attraction.ImageUrl" alt="@attraction.Name"
                         onerror="this.src='https://picsum.photos/id/@(attraction.Id + 10)/400/300'">
                    <div class="attraction-content">
                        <h3 class="attraction-title">@attraction.Name</h3>
                        <p class="attraction-description">@(attraction.Description.Length > 100 ?
                            attraction.Description.Substring(0, 100) + "..." : attraction.Description)</p>
                        <a href="/Home/AttractionDetail/@attraction.Id" class="attraction-link">
                            Descobrir Mais <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            }
        </div>

        @if (allAttractions.Count > 8)
        {
            <div class="text-center mt-4" id="verMaisWrapper">
                <button id="verMaisBtn" class="btn-outline-custom">
                    Ver Mais Atrações <i class="fas fa-chevron-down ms-2"></i>
                </button>
            </div>

            <!-- Grupo extra: cards 9 em diante, oculto até clicar em Ver Mais -->
            <div class="attractions-grid grid-hidden" id="gridExtra" style="margin-top:32px;">
                @foreach (var attraction in allAttractions.Skip(8))
                {
                    <div class="attraction-card" data-category="@attraction.Category" data-id="@attraction.Id"
                         data-name="@attraction.Name.ToLower()" data-desc="@attraction.Description.ToLower()">
                        <img class="attraction-image" src="@attraction.ImageUrl" alt="@attraction.Name"
                             onerror="this.src='https://picsum.photos/id/@(attraction.Id + 10)/400/300'">
                        <div class="attraction-content">
                            <h3 class="attraction-title">@attraction.Name</h3>
                            <p class="attraction-description">@(attraction.Description.Length > 100 ?
                                attraction.Description.Substring(0, 100) + "..." : attraction.Description)</p>
                            <a href="/Home/AttractionDetail/@attraction.Id" class="attraction-link">
                                Descobrir Mais <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

    <!-- Mapa Interativo -->
    <section class="section section-white" id="mapa">
        <div class="container">
            <div class="text-center">
                <span class="section-tag">Onde Encontrar</span>
                <h2 class="section-title">Mapa das Atrações</h2>
                <div class="section-divider"></div>
                <p class="text-secondary fs-5 mb-4" style="max-width: 600px; margin: 0 auto;">
                    Veja a localização de cada ponto turístico e planeje seu roteiro por Barra Bonita.
                </p>
            </div>
            <div id="attractionsMap" class="attractions-map"></div>
        </div>
    </section>

    <!-- Calendar Section -->
    <section class="section section-white" id="calendario">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-5 mb-lg-0">
                    <span class="section-tag">AGENDA CULTURAL</span>
                    <h2 class="section-title">Calendário<br>Completo de<br>Eventos</h2>
                    <p class="text-secondary fs-5 mb-4">
                        Não perca nenhuma das grandes celebrações que tornam Barra Bonita o coração pulsante do interior.
                    </p>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <i class="fas fa-calendar-alt" style="color: #FF5A00; font-size: 20px;"></i>
                            <span class="text-secondary">Atualizado mensalmente</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <i class="fas fa-ticket-alt" style="color: #FF5A00; font-size: 20px;"></i>
                            <span class="text-secondary">Eventos gratuitos em sua maioria</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-8">
                    @if (upcomingEvents != null && upcomingEvents.Any())
                    {
                        @foreach (var ev in upcomingEvents)
                        {
                            var evColor = !string.IsNullOrEmpty(ev.Color) ? ev.Color : "#FF5A00";
                            var startMonth = ev.StartDate.ToString("MMM", new System.Globalization.CultureInfo("pt-BR")).ToUpper();
                            var dayDisplay = ev.EndDate.HasValue && ev.EndDate.Value.Date != ev.StartDate.Date
                                ? ev.StartDate.Day + "-" + ev.EndDate.Value.Day
                                : ev.StartDate.Day.ToString();
                            <div class="event-card mb-4">
                                <div class="event-date-small" style="background: @evColor;">
                                    <span class="event-month-small">@startMonth</span>
                                    <span class="event-day-small">@dayDisplay</span>
                                </div>
                                <div class="event-content">
                                    <span class="event-category" style="color: @evColor;">@ev.EventType?.ToUpper()</span>
                                    <h3 class="event-title-small">@ev.Title</h3>
                                    <p class="event-description">@ev.Description</p>
                                    @if (!string.IsNullOrEmpty(ev.Location))
                                    {
                                        <p class="event-location">
                                            <i class="fas fa-map-marker-alt me-1"></i>@ev.Location
                                        </p>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-calendar-times fa-2x mb-3" style="color: #ccc;"></i>
                            <p class="text-secondary">Nenhum evento próximo cadastrado.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

                        <!-- Hospitality Section - Com Imagens -->
