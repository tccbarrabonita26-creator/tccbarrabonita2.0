@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using BarraBonitaTurismo.Models
@{
    ViewData["Title"] = "Barra Bonita - Estância Turística | Portal Oficial";
    var cityInfo = ViewBag.CityInfo as CityInfo;
    var upcomingEvents = ViewBag.UpcomingEvents as List<Event>;
    var allAttractions = ViewBag.AllAttractions as List<Attraction>;
    var faqs = ViewBag.FAQs as List<FAQ>;
    var guideItemsByType = ViewBag.GuideItemsByType as Dictionary<string, List<GuideItem>>;
}

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom">
    <div class="container">
        <a class="navbar-brand-custom" href="#hero">Barra<span>Bonita</span></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link-custom" href="#hero">INÍCIO</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#historia">HISTÓRIA</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#atracoes">ATRAÇÕES</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#calendario">CALENDÁRIO</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#hospitalidade">HOSPITALIDADE</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#faq">FAQ</a></li>
                <li class="nav-item"><a class="nav-link-custom" href="#contato">CONTATO</a></li>
            </ul>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="hero" id="hero" style="background-image: url('https://picsum.photos/id/104/1920/1080'); background-size: cover; background-position: center;">
    <div class="container text-center">
        <div class="hero-badge">A Pérola do Tietê</div>
        <h1 class="hero-title">
            <small>Boas-vindas à</small>
            <large>Barra Bonita</large>
        </h1>
        <p class="hero-subtitle">
            Descubra a eclusa mais famosa do Brasil e encante-se com a hospitalidade de uma estância turística inesquecível.
        </p>
        <a href="#atracoes" class="btn-primary-custom">
            Começar Exploração
            <i class="fas fa-arrow-right"></i>
        </a>
    </div>
    <div class="hero-scroll">
        <div class="d-flex flex-column align-items-center">
            <span class="text-white small fw-bold tracking-wide">Role para descobrir</span>
            <i class="fas fa-chevron-down text-white mt-2 animate-bounce"></i>
        </div>
    </div>
</section>

<!-- History Section -->
<section class="section section-white" id="historia">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="history-image">
                    <img src="https://picsum.photos/id/96/600/500" alt="História de Barra Bonita" class="img-fluid">
                </div>
            </div>
            <div class="col-lg-6">
                <span class="section-tag">Nossa Herança</span>
                <h2 class="section-title">Um destino forjado pelas águas e pelo tempo</h2>
                <p class="fs-5 text-secondary">
                    @Html.Raw(cityInfo?.History?.Split('\n')[0])
                </p>
                <div class="history-quote">
                    "Aqui o rio é limpo, a história é viva e cada pôr do sol nas águas é uma celebração da natureza."
                </div>
                <div class="stats">
                    <div>
                        <div class="stat-number">@(cityInfo?.Foundation?.Split(' ').LastOrDefault() ?? "1883")</div>
                        <div class="stat-label">Fundação Oficial</div>
                    </div>
                    <div>
                        <div class="stat-number">1973</div>
                        <div class="stat-label">Inauguração da Eclusa</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Attractions Section -->
<section class="section section-light" id="atracoes">
    <div class="container">
        <div class="text-center">
            <span class="section-tag">Explore a Cidade</span>
            <h2 class="section-title">Atrações Principais</h2>
            <div class="section-divider"></div>
        </div>

        <div class="filters-container">
            <button class="filter-btn filter-btn-active" data-filter="all">Todas</button>
            <button class="filter-btn filter-btn-inactive" data-filter="Náutica">Náutica</button>
            <button class="filter-btn filter-btn-inactive" data-filter="Cultura">Cultura</button>
            <button class="filter-btn filter-btn-inactive" data-filter="Natureza">Natureza</button>
            <button class="filter-btn filter-btn-inactive" data-filter="Lazer">Lazer</button>
        </div>

        <div class="attractions-grid">
            @foreach (var attraction in allAttractions)
            {
                <div class="attraction-card" data-category="@attraction.Category">
                    <img class="attraction-image" 
                         src="@attraction.ImageUrl" 
                         alt="@attraction.Name"
                         onerror="this.src='https://picsum.photos/id/@(attraction.Id + 10)/400/300'">
                    <div class="attraction-content">
                        <h3 class="attraction-title">@attraction.Name</h3>
                        <p class="attraction-description">@(attraction.Description.Length > 100 ? attraction.Description.Substring(0, 100) + "..." : attraction.Description)</p>
                        <a href="#" class="attraction-link" onclick="BarraBonitaTurismo.openModal('@attraction.Name', '@Html.Raw(attraction.Description.Replace("'", "\\'"))', '@attraction.ImageUrl'); return false;">
                            Descobrir Mais <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Calendar Section -->
<section class="section section-white" id="calendario">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 mb-5 mb-lg-0">
                <span class="section-tag">AGENDA CULTURAL</span>
                <h2 class="section-title">Calendário<br>Completo de<br>Eventos</h2>
                <p class="text-secondary fs-5 mb-4">
                    Não perca nenhuma das grandes celebrações que tornam Barra Bonita o coração pulsante do interior.
                </p>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fas fa-calendar-alt" style="color: #FF5A00; font-size: 20px;"></i>
                        <span class="text-secondary">Atualizado mensalmente</span>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <i class="fas fa-ticket-alt" style="color: #FF5A00; font-size: 20px;"></i>
                        <span class="text-secondary">Eventos gratuitos em sua maioria</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <!-- Carnaval / Festividades -->
                <div class="event-card mb-4">
                    <div class="event-date-small" style="background: linear-gradient(135deg, #FF5A00, #E04E00);">
                        <span class="event-month-small">FEV</span>
                        <span class="event-day-small">Anual</span>
                    </div>
                    <div class="event-content">
                        <span class="event-category" style="color: #FF5A00;">FESTIVIDADES</span>
                        <h3 class="event-title-small">CarnaBarra</h3>
                        <p class="event-description">O mais tradicional carnaval de rua da região, com desfiles na avenida da orla e trios elétricos que agitam milhares de turistas.</p>
                    </div>
                </div>

                <!-- Festival Gastronômico -->
                <div class="event-card mb-4">
                    <div class="event-date-small" style="background: linear-gradient(135deg, #FF5A00, #E04E00);">
                        <span class="event-month-small">JUL</span>
                        <span class="event-day-small">10-31</span>
                    </div>
                    <div class="event-content">
                        <span class="event-category" style="color: #FF5A00;">GASTRONOMIA</span>
                        <h3 class="event-title-small">Festival de Inverno & Festival do Peixe</h3>
                        <p class="event-description">Gastronomia caipira refinada, shows de MPB e Jazz e a famosa feira de malhas e artesanatos na Praça do Teleférico.</p>
                    </div>
                </div>

                <!-- Festa do Rio / Religioso -->
                <div class="event-card mb-4">
                    <div class="event-date-small" style="background: linear-gradient(135deg, #8B5CF6, #7C3AED);">
                        <span class="event-month-small">AGO</span>
                        <span class="event-day-small">15</span>
                    </div>
                    <div class="event-content">
                        <span class="event-category" style="color: #8B5CF6;">RELIGIOSO</span>
                        <h3 class="event-title-small">Festa do Rio - Nossa Sra dos Navegantes</h3>
                        <p class="event-description">Procissão fluvial emocionante com centenas de barcos decorados, missa campal e queima de fogos sobre o espelho d'água.</p>
                    </div>
                </div>

                <!-- Semana Náutica / Esporte -->
                <div class="event-card mb-4">
                    <div class="event-date-small" style="background: linear-gradient(135deg, #0EA5E9, #0C8BC8);">
                        <span class="event-month-small">SET</span>
                        <span class="event-day-small">07</span>
                    </div>
                    <div class="event-content">
                        <span class="event-category" style="color: #0EA5E9;">ESPORTE & CIDADANIA</span>
                        <h3 class="event-title-small">Semana Náutica</h3>
                        <p class="event-description">Competições de canoagem, remo e regatas de vela, celebrando a independência com muita adrenalina nas águas.</p>
                    </div>
                </div>

                <!-- Natal -->
                <div class="event-card mb-4">
                    <div class="event-date-small" style="background: linear-gradient(135deg, #FF5A00, #E04E00);">
                        <span class="event-month-small">DEZ</span>
                        <span class="event-day-small">20-25</span>
                    </div>
                    <div class="event-content">
                        <span class="event-category" style="color: #FF5A00;">NATAL</span>
                        <h3 class="event-title-small">Natal Iluminado nas Águas</h3>
                        <p class="event-description">A chegada do Papai Noel de barco, árvores flutuantes e toda a orla decorada com milhões de microlâmpadas de LED.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Hospitality Section - Com Imagens -->
<section class="section section-light" id="hospitalidade">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-tag">HOSPEDAGEM & GASTRONOMIA</span>
            <h2 class="section-title">Onde a Experiência Acontece</h2>
            <div class="section-divider"></div>
        </div>

        <div class="row g-5">
            <!-- Rede Hoteleira -->
            <div class="col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="hospitality-icon">
                        <i class="fas fa-hotel fa-2x" style="color: #FF5A00;"></i>
                    </div>
                    <h3 class="hospitality-section-title mb-0">Rede Hoteleira</h3>
                </div>
                
                <div class="hospitality-grid">
                    <div class="hospitality-card">
                        <img src="https://picsum.photos/id/164/400/200" alt="Hotel Estância" class="hospitality-card-image" onerror="this.src='https://placehold.co/400x200/FF5A00/white?text=Hotel'">
                        <div class="hospitality-card-content">
                            <h4 class="hospitality-card-title">Hotel Estância Barra Bonita</h4>
                            <p class="hospitality-card-description">Referência em lazer com parque aquático completo.</p>
                            <span class="hospitality-card-tag">RESORT DE LAZER</span>
                        </div>
                    </div>
                    <div class="hospitality-card">
                        <img src="https://picsum.photos/id/259/400/200" alt="Pousada da Orla" class="hospitality-card-image" onerror="this.src='https://placehold.co/400x200/FF5A00/white?text=Pousada'">
                        <div class="hospitality-card-content">
                            <h4 class="hospitality-card-title">Pousada da Orla</h4>
                            <p class="hospitality-card-description">Vista privilegiada para o rio e café da manhã colonial.</p>
                            <span class="hospitality-card-tag">POUSADA BOUTIQUE</span>
                        </div>
                    </div>
                    <div class="hospitality-card">
                        <img src="https://picsum.photos/id/179/400/200" alt="Hotel Turi" class="hospitality-card-image" onerror="this.src='https://placehold.co/400x200/FF5A00/white?text=Hotel'">
                        <div class="hospitality-card-content">
                            <h4 class="hospitality-card-title">Hotel Turi</h4>
                            <p class="hospitality-card-description">Localização central, ideal para executivos e turismo histórico.</p>
                            <span class="hospitality-card-tag">HOTEL EXECUTIVO</span>
                        </div>
                    </div>
                    <div class="hospitality-card">
                        <img src="https://picsum.photos/id/174/400/200" alt="Hotel Beira Rio" class="hospitality-card-image" onerror="this.src='https://placehold.co/400x200/FF5A00/white?text=Hotel'">
                        <div class="hospitality-card-content">
                            <h4 class="hospitality-card-title">Hotel Beira Rio</h4>
                            <p class="hospitality-card-description">Acesso direto ao deck e passeios exclusivos de lancha.</p>
                            <span class="hospitality-card-tag">HOTEL TURÍSTICO</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Guia Gastronômico -->
            <div class="col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="hospitality-icon">
                        <i class="fas fa-utensils fa-2x" style="color: #FF5A00;"></i>
                    </div>
                    <h3 class="hospitality-section-title mb-0">Guia Gastronômico</h3>
                </div>
                
                <div class="hospitality-grid">
                    <div class="hospitality-card">
                        <img src="https://picsum.photos/id/108/400/200" alt="Restaurante do Porto" class="hospitality-card-image" onerror="this.src='https://placehold.co/400x200/FF5A00/white?text=Restaurante'">
                        <div class="hospitality-card-content">
                            <h4 class="hospitality-card-title">Restaurante do Porto</h4>
                            <p class="hospitality-card-description">Especialista no tradicional "Peixe na Telha" e porções de lambari frito.</p>
                            <span class="hospitality-card-tag">Aberto Almoço/Jantar</span>
                        </div>
                    </div>
                    <div class="hospitality-card">
                        <img src="https://picsum.photos/id/132/400/200" alt="Varanda Grill Orla" class="hospitality-card-image" onerror="this.src='https://placehold.co/400x200/FF5A00/white?text=Restaurante'">
                        <div class="hospitality-card-content">
                            <h4 class="hospitality-card-title">Varanda Grill Orla</h4>
                            <p class="hospitality-card-description">Carnes nobres com a melhor vista para a eclusagem dos navios.</p>
                            <span class="hospitality-card-tag">Música ao Vivo</span>
                        </div>
                    </div>
                    <div class="hospitality-card">
                        <img src="https://picsum.photos/id/120/400/200" alt="Cantina da Praça" class="hospitality-card-image" onerror="this.src='https://placehold.co/400x200/FF5A00/white?text=Cantina'">
                        <div class="hospitality-card-content">
                            <h4 class="hospitality-card-title">Cantina da Praça</h4>
                            <p class="hospitality-card-description">Massas artesanais e pizzas em forno a lenha no centro histórico.</p>
                            <span class="hospitality-card-tag">Atmosfera Familiar</span>
                        </div>
                    </div>
                    <div class="hospitality-card">
                        <img src="https://picsum.photos/id/111/400/200" alt="Doceria Tietê" class="hospitality-card-image" onerror="this.src='https://placehold.co/400x200/FF5A00/white?text=Doceria'">
                        <div class="hospitality-card-content">
                            <h4 class="hospitality-card-title">Doceria Tietê</h4>
                            <p class="hospitality-card-description">Os melhores doces caseiros, compotas e café com grãos locais.</p>
                            <span class="hospitality-card-tag">Café & Sobremesa</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="section section-white" id="faq">
    <div class="container" style="max-width: 800px;">
        <div class="text-center">
            <span class="section-tag">Suporte ao Turista</span>
            <h2 class="section-title">Dúvidas Frequentes</h2>
            <div class="section-divider"></div>
        </div>

        @foreach (var faq in faqs)
        {
            <div class="faq-item">
                <button class="faq-question">
                    @faq.Question
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer">
                    @faq.Answer
                </div>
            </div>
        }
    </div>
</section>

<!-- Modal -->
<div class="modal-custom" id="modal">
    <div class="modal-content-custom">
        <button class="modal-close">&times;</button>
        <img class="modal-image" id="modalImage" src="" alt="">
        <h3 class="modal-title" id="modalTitle"></h3>
        <p id="modalDesc" class="text-secondary"></p>
    </div>
</div>

<!-- Footer -->
<footer class="footer" id="contato">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-5">
                <a href="#" class="footer-logo">Barra<span>Bonita</span></a>
                <p class="mt-4">Secretaria Municipal de Turismo e Cultura. Promovendo o desenvolvimento sustentável de Barra Bonita.</p>
            </div>
            <div class="col-lg-3">
                <h4 class="footer-title">Navegação</h4>
                <div class="footer-divider"></div>
                <ul class="footer-links">
                    <li><a href="#hero">Início</a></li>
                    <li><a href="#historia">Nossa História</a></li>
                    <li><a href="#atracoes">Atrações</a></li>
                    <li><a href="#calendario">Eventos</a></li>
                </ul>
            </div>
            <div class="col-lg-4">
                <h4 class="footer-title">Atendimento</h4>
                <div class="footer-divider"></div>
                <div class="footer-contact">
                    <i class="fas fa-phone"></i>
                    <div><strong>Telefone</strong><br>(14) 3604-4000</div>
                </div>
                <div class="footer-contact">
                    <i class="fas fa-envelope"></i>
                    <div><strong>E-mail</strong><br>turismo@barrabonita.sp.gov.br</div>
                </div>
                <div class="footer-contact">
                    <i class="fas fa-map-marker-alt"></i>
                    <div><strong>Endereço</strong><br>Praça Waldemar Lopes Ferraz, s/n<br>Barra Bonita - SP</div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2026 Estância Turística de Barra Bonita. Todos os direitos reservados.</p>
        </div>
    </div>
</footer>