@section Scripts {
    <script>
        // ============================================
        // BUSCA + FILTRO POR CATEGORIA
        // ============================================
        (function () {
            const searchInput = document.getElementById('attractionSearch');
            const filterBtns  = document.querySelectorAll('.filter-btn');
            const noResults   = document.getElementById('noResultsMsg');
            const verMaisWrapper = document.getElementById('verMaisWrapper');
            const gridExtra   = document.getElementById('gridExtra');
            let extraVisible  = false;

            function applyFilters() {
                const activeBtn = document.querySelector('.filter-btn-active');
                const filter    = activeBtn ? activeBtn.dataset.filter : 'all';
                const search    = searchInput ? searchInput.value.toLowerCase().trim() : '';

                // Filtra todos os cards dos dois grids
                const allCards = document.querySelectorAll('.attraction-card');
                let totalVisible = 0;

                allCards.forEach(card => {
                    const matchesFilter = filter === 'all' || card.dataset.category === filter;
                    const matchesSearch = !search || card.dataset.name.includes(search) || card.dataset.desc.includes(search);
                    const show = matchesFilter && matchesSearch;

                    // Respeita qual grid o card pertence
                    const inExtra = card.closest('#gridExtra') !== null;
                    if (show) {
                        totalVisible++;
                        // Cards do extra só aparecem se o usuário clicou Ver Mais E há filtro/busca
                        // OU se extraVisible já está true
                        card.style.display = (inExtra && !extraVisible) ? 'none' : '';
                    } else {
                        card.style.display = 'none';
                    }
                });

                noResults.style.display = totalVisible === 0 ? 'block' : 'none';

                // Botão Ver Mais: só mostra se há cards no extra E extra está oculto
                if (verMaisWrapper && gridExtra) {
                    const extraCards = gridExtra.querySelectorAll('.attraction-card');
                    const extraHasVisible = Array.from(extraCards).some(c => {
                        const matchesFilter = filter === 'all' || c.dataset.category === filter;
                        const matchesSearch = !search || c.dataset.name.includes(search) || c.dataset.desc.includes(search);
                        return matchesFilter && matchesSearch;
                    });
                    verMaisWrapper.style.display = (!extraVisible && extraHasVisible) ? 'block' : 'none';
                }
            }

            // Botão Ver Mais
            const verMaisBtn = document.getElementById('verMaisBtn');
            if (verMaisBtn) {
                verMaisBtn.addEventListener('click', function () {
                    extraVisible = true;
                    if (gridExtra) gridExtra.classList.remove('grid-hidden');
                    if (verMaisWrapper) verMaisWrapper.style.display = 'none';
                    applyFilters();
                });
            }

            // Filtros de categoria
            filterBtns.forEach(btn => {
                btn.addEventListener('click', function () {
                    filterBtns.forEach(b => {
                        b.classList.remove('filter-btn-active');
                        b.classList.add('filter-btn-inactive');
                    });
                    this.classList.add('filter-btn-active');
                    this.classList.remove('filter-btn-inactive');
                    applyFilters();
                });
            });

            // Busca em tempo real
            if (searchInput) {
                searchInput.addEventListener('input', applyFilters);
            }

            applyFilters();
        })();

        // ============================================
        // MAPA INTERATIVO (LEAFLET)
        // ============================================
        (function () {
            const mapEl = document.getElementById('attractionsMap');
            if (!mapEl || typeof L === 'undefined') return;

            const attractions = @Html.Raw(mapMarkersJson);

            if (attractions.length === 0) return;

            const avgLat = attractions.reduce((sum, a) => sum + a.lat, 0) / attractions.length;
            const avgLng = attractions.reduce((sum, a) => sum + a.lng, 0) / attractions.length;

            const map = L.map('attractionsMap').setView([avgLat, avgLng], 14);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors',
                maxZoom: 19
            }).addTo(map);

            const customIcon = L.divIcon({
                className: 'map-marker-custom',
                html: '<i class="fas fa-map-marker-alt"></i>',
                iconSize: [30, 30],
                iconAnchor: [15, 30]
            });

            attractions.forEach(a => {
                const marker = L.marker([a.lat, a.lng], { icon: customIcon }).addTo(map);
                marker.bindPopup(`
                    <strong>${a.name}</strong><br>
                    <span style="color:#FF5A00; font-size:12px; font-weight:600;">${a.category}</span><br>
                    <a href="${a.url}" style="color:#03140C; font-weight:600; font-size:13px;">Ver detalhes →</a>
                `);
            });
        })();
    </script>
}