@using BarraBonitaTurismo.Models
@{
    ViewData["Title"] = "Barra Bonita - Estância Turística | Portal Oficial";
    var cityInfo = ViewBag.CityInfo as CityInfo;
    var upcomingEvents = ViewBag.UpcomingEvents as List<Event>;
    var featuredAttractions = ViewBag.FeaturedAttractions as List<Attraction>;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Barra Bonita - Estância Turística | Portal Oficial</title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;family=Playfair+Display:wght@700;900&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <style>
        /* CSS Puro - Sem  */
        :root {
            --primary: #0ea5e9;
            --secondary: #10b981;
        }
        
        body {
            font-family: "Plus Jakarta Sans", sans-serif;
            -webkit-font-smoothing: antialiased;
            color: #0f172a;
            background-color: #f8fafc;
        }
        
        .hero-gradient {
            background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%);
        }
        
        .nav-blur {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        
        #mobile-menu-toggle:checked ~ #mobile-menu {
            display: flex;
        }
        
        .section-spacing {
            padding-top: 6rem;
            padding-bottom: 6rem;
        }
        
         (min-width: 768px) {
            .section-spacing {
                padding-top: 12rem;
                padding-bottom: 12rem;
            }
        }
        
        .filter-btn {
            padding-left: 1.5rem;
            padding-right: 1.5rem;
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
            border-radius: 9999px;
            font-size: 0.875rem;
            font-weight: 700;
            border-width: 1px;
            transition-property: all;
            transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
            transition-duration: 150ms;
            cursor: pointer;
        }
        
        .filter-btn-active {
            background-color: #0ea5e9;
            color: white;
            border-color: #0ea5e9;
            box-shadow: 0 10px 15px -3px rgba(14, 165, 233, 0.2);
        }
        
        .filter-btn-inactive {
            border-color: #e2e8f0;
            color: #475569;
            background-color: transparent;
        }
        
        .filter-btn-inactive:hover {
            border-color: #0ea5e9;
            color: #0ea5e9;
        }
        
         (prefers-color-scheme: dark) {
            body {
                color: #f1f5f9;
                background-color: #0f172a;
            }
            .filter-btn-inactive {
                border-color: #334155;
                color: #94a3b8;
            }
        }
        
        details > summary {
            list-style: none;
            cursor: pointer;
        }
        
        details > summary::-webkit-details-marker {
            display: none;
        }
        
        .faq-card[open] .faq-icon {
            transform: rotate(180deg);
        }
        
        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 200;
            background-color: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(4px);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        
        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }
        
        .modal-container {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.95);
            z-index: 201;
            width: 95%;
            max-width: 1024px;
            max-height: 90vh;
            background-color: white;
            border-radius: 2.5rem;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            box-shadow: 0 10px 30px rgba(135, 206, 250, 0.5);
        }
        
         (prefers-color-scheme: dark) {
            .modal-container {
                background-color: #0f172a;
            }
        }
        
         (min-width: 768px) {
            .modal-container {
                flex-direction: row;
            }
        }
        
        .modal-container.active {
            transform: translate(-50%, -50%) scale(1);
            opacity: 1;
            pointer-events: auto;
        }
        
        /* Animações */
         bounce {
            0%, 100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-10px);
            }
        }
        
        .animate-bounce {
            animation: bounce 1s infinite;
        }
        
        /* Line clamp */
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        /* Attraction card */
        .attraction-card {
            cursor: pointer;
        }
        
        /* Dark mode helper */
        .dark\:bg-slate-900 {
            background-color: #0f172a;
        }
        
        .dark\:text-white {
            color: white;
        }
    </style>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#0ea5e9",
                        secondary: "#10b981",
                    },
                    fontFamily: {
                        sans: ["Plus Jakarta Sans", "sans-serif"],
                        display: ["Playfair Display", "serif"],
                    },
                },
            },
        };
    </script>
</head>

<body>
    <nav
        class="fixed top-0 left-0 right-0 z-[100] bg-white/95 dark:bg-slate-900/95 nav-blur border-b border-slate-200/50 dark:border-slate-800/50">
        <div class="max-w-7xl mx-auto px-4 sm:px-8 h-24 flex items-center justify-between">
            <a class="flex items-center gap-3" href="#hero">
                <div
                    class="w-11 h-11 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg shadow-primary/20">
                    <span class="material-symbols-outlined text-3xl">waves</span>
                </div>
                <span class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">Barra <span
                        class="text-primary">Bonita</span></span>
            </a>
            <div class="hidden lg:flex items-center gap-8">
                <a class="font-semibold text-slate-600 hover:text-primary dark:text-slate-300 dark:hover:text-primary transition-all text-sm uppercase tracking-wide"
                    href="#hero">Início</a>
                <a class="font-semibold text-slate-600 hover:text-primary dark:text-slate-300 dark:hover:text-primary transition-all text-sm uppercase tracking-wide"
                    href="#historia">História</a>
                <a class="font-semibold text-slate-600 hover:text-primary dark:text-slate-300 dark:hover:text-primary transition-all text-sm uppercase tracking-wide"
                    href="#atracoes">Atrações</a>
                <a class="font-semibold text-slate-600 hover:text-primary dark:text-slate-300 dark:hover:text-primary transition-all text-sm uppercase tracking-wide"
                    href="#calendario">Calendário</a>
                <a class="font-semibold text-slate-600 hover:text-primary dark:text-slate-300 dark:hover:text-primary transition-all text-sm uppercase tracking-wide"
                    href="#guia">Guia</a>
                <a class="font-semibold text-slate-600 hover:text-primary dark:text-slate-300 dark:hover:text-primary transition-all text-sm uppercase tracking-wide"
                    href="#faq">FAQ</a>
                <a class="font-semibold text-slate-600 hover:text-primary dark:text-slate-300 dark:hover:text-primary transition-all text-sm uppercase tracking-wide"
                    href="#contato">Contato</a>
            </div>
            <div class="flex items-center gap-4">
                <input class="hidden" id="mobile-menu-toggle" type="checkbox" />
                <label class="lg:hidden p-2 text-slate-600 dark:text-slate-300 cursor-pointer" for="mobile-menu-toggle">
                    <span class="material-symbols-outlined text-3xl">menu</span>
                </label>
                <div class="hidden absolute top-24 left-0 right-0 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 flex-col p-8 gap-6 shadow-2xl lg:hidden"
                    id="mobile-menu">
                    <a class="text-xl font-bold text-slate-900 dark:text-white" href="#hero">Início</a>
                    <a class="text-xl font-bold text-slate-900 dark:text-white" href="#historia">História</a>
                    <a class="text-xl font-bold text-slate-900 dark:text-white" href="#atracoes">Atrações</a>
                    <a class="text-xl font-bold text-slate-900 dark:text-white" href="#calendario">Calendário</a>
                    <a class="text-xl font-bold text-slate-900 dark:text-white" href="#guia">Guia</a>
                    <a class="text-xl font-bold text-slate-900 dark:text-white" href="#faq">FAQ</a>
                    <a class="text-xl font-bold text-slate-900 dark:text-white" href="#contato">Contato</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden" id="hero">
        <div class="absolute inset-0">
            <img alt="Vista aérea majestosa do Rio Tietê em Barra Bonita" class="w-full h-full object-cover"
                src="/images/hero-bg.jpg" />
            <div class="absolute inset-0 hero-gradient"></div>
        </div>
        <div class="relative z-10 text-center px-6 max-w-6xl">
            <span
                class="inline-block px-4 py-2 bg-white/10 backdrop-blur-md text-white rounded-full text-sm font-bold tracking-widest uppercase mb-8 border border-white/20">A
                Pérola do Tietê</span>
            <h1
                class="font-display text-5xl sm:text-7xl md:text-9xl text-white mb-8 leading-[1] font-black tracking-tight">
                Navegue pela <br /> <span class="italic text-primary">História.</span>
            </h1>
            <p class="text-xl sm:text-2xl text-slate-100 mb-12 max-w-3xl mx-auto font-light leading-relaxed">
                Descubra a eclusa mais famosa do Brasil e encante-se com a hospitalidade de uma estância turística
                inesquecível.
            </p>
            <div class="flex flex-col sm:flex-row gap-6 justify-center items-stretch sm:items-center">
                <a class="px-10 py-5 bg-primary text-white rounded-full font-bold text-lg hover:bg-sky-400 active:scale-95 transition-all flex items-center justify-center gap-3 shadow-2xl shadow-primary/30"
                    href="#atracoes">
                    Começar Exploração <span class="material-symbols-outlined">explore</span>
                </a>
                <a class="px-10 py-5 bg-white/10 hover:bg-white/20 active:scale-95 text-white backdrop-blur-md border border-white/30 rounded-full font-bold text-lg transition-all flex items-center justify-center"
                    href="#historia">
                    Vídeo Institucional
                </a>
            </div>
        </div>
        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-white/50">
            <span class="text-xs font-bold uppercase tracking-[0.3em]">Role para descobrir</span>
            <span class="material-symbols-outlined animate-bounce text-3xl">expand_more</span>
        </div>
    </section>

    <!-- History Section -->
    <section class="section-spacing bg-white dark:bg-slate-900" id="historia">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-24 items-center">
                <div class="relative group">
                    <div
                        class="absolute -top-12 -left-12 w-64 h-64 bg-primary/5 rounded-full blur-3xl group-hover:bg-primary/10 transition-colors">
                    </div>
                    <div
                        class="rounded-[3rem] overflow-hidden shadow-2xl relative z-10 aspect-[4/5] border-8 border-white dark:border-slate-800">
                        <img alt="Centro histórico de Barra Bonita e arquitetura clássica"
                            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                            src="/images/history.jpg" />
                    </div>
                    <div
                        class="absolute -bottom-10 -right-10 hidden lg:block w-72 h-72 border-[16px] border-secondary/10 rounded-[3rem] -z-10">
                    </div>
                </div>
                <div>
                    <span class="text-secondary font-bold tracking-[0.2em] uppercase text-sm mb-6 block">Nossa
                        Herança</span>
                    <h2 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold mb-10 dark:text-white leading-tight">
                        Um destino forjado pelas águas e pelo tempo</h2>
                    <div class="space-y-6 mb-12">
                        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
                            @Html.Raw(cityInfo?.History?.Split('\n')[0])
                        </p>
                        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed font-light italic border-l-4 border-primary pl-6">
                            "Aqui o rio é limpo, a história é viva e cada pôr do sol nas águas é uma celebração da natureza."
                        </p>
                    </div>
                    <div class="grid grid-cols-2 gap-8">
                        <div class="p-8 bg-slate-50 dark:bg-slate-800 rounded-[2rem] border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-shadow">
                            <span class="text-primary font-bold text-4xl block mb-2">@(cityInfo?.Foundation?.Split(' ').LastOrDefault() ?? "1890")</span>
                            <span class="text-sm text-slate-500 font-bold uppercase tracking-wider">Fundação Oficial</span>
                        </div>
                        <div class="p-8 bg-slate-50 dark:bg-slate-800 rounded-[2rem] border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-shadow">
                            <span class="text-secondary font-bold text-4xl block mb-2">1973</span>
                            <span class="text-sm text-slate-500 font-bold uppercase tracking-wider">Inauguração da Eclusa</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Attractions Section -->
    <section class="section-spacing bg-slate-50 dark:bg-slate-950" id="atracoes">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-24">
                <span class="text-primary font-bold tracking-[0.2em] uppercase text-sm mb-6 block">Explore a Cidade</span>
                <h2 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold mb-8 dark:text-white">Atrações Principais</h2>
                <div class="w-24 h-2 bg-primary mx-auto rounded-full mb-10"></div>
                <div class="flex flex-wrap justify-center gap-4 mb-16">
                    <button class="filter-btn filter-btn-active" data-filter="all">Todas</button>
                    <button class="filter-btn filter-btn-inactive" data-filter="Náutica">Náutica</button>
                    <button class="filter-btn filter-btn-inactive" data-filter="Cultura">Cultura</button>
                    <button class="filter-btn filter-btn-inactive" data-filter="Natureza">Natureza</button>
                    <button class="filter-btn filter-btn-inactive" data-filter="Lazer">Lazer</button>
                </div>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" id="attractions-grid">
                @foreach (var attraction in ViewBag.AllAttractions)
                {
                    <button class="attraction-card group bg-white dark:bg-slate-900 rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-slate-200 dark:border-slate-800 text-left"
                            data-category="@attraction.Category"
                            data-id="@attraction.Id"
                            data-title="@attraction.Name"
                            data-desc="@attraction.Description"
                            data-images='@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(new[] { attraction.ImageUrl }))'>
                        <div class="h-64 overflow-hidden relative">
                            <img alt="@attraction.Name"
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                 src="@attraction.ImageUrl" />
                            <div class="absolute top-6 right-6 px-4 py-2 rounded-full text-[10px] font-bold uppercase tracking-widest text-white shadow-xl"
                                 style="background-color: @(attraction.Category == "Náutica" ? "#0ea5e9" : attraction.Category == "Cultura" ? "#10b981" : attraction.Category == "Lazer" ? "#f97316" : "#8b5cf6")">
                                @attraction.Category
                            </div>
                        </div>
                        <div class="p-8">
                            <h3 class="text-2xl font-bold mb-4 dark:text-white group-hover:text-primary transition-colors">@attraction.Name</h3>
                            <p class="text-slate-600 dark:text-slate-400 mb-6 line-clamp-2">@(attraction.Description.Length > 100 ? attraction.Description.Substring(0, 100) + "..." : attraction.Description)</p>
                            <span class="inline-flex items-center gap-2 font-bold text-primary group-hover:gap-4 transition-all text-sm uppercase tracking-widest">
                                Descobrir Mais <span class="material-symbols-outlined text-lg">arrow_forward</span>
                            </span>
                        </div>
                    </button>
                }
            </div>
        </div>
    </section>

    <!-- Modal for Attractions -->
    <div class="modal-overlay" id="attraction-overlay"></div>
    <div class="modal-container" id="attraction-modal">
        <button class="absolute top-6 right-6 z-[210] w-12 h-12 bg-white/90 dark:bg-slate-800/90 rounded-full flex items-center justify-center text-slate-900 dark:text-white shadow-lg hover:bg-primary hover:text-white transition-all" id="close-modal">
            <span class="material-symbols-outlined">close</span>
        </button>
        <div class="md:w-1/2 relative bg-slate-100 dark:bg-slate-800 overflow-hidden min-h-[300px]">
            <img alt="Atração" class="w-full h-full object-cover transition-opacity duration-500" id="modal-image" />
            <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-4 p-4 bg-black/20 backdrop-blur-md rounded-2xl border border-white/10" id="modal-dots"></div>
            <button class="absolute top-1/2 left-4 -translate-y-1/2 w-10 h-10 bg-black/30 text-white rounded-full flex items-center justify-center hover:bg-black/50 transition-all" onclick="prevImage()">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button class="absolute top-1/2 right-4 -translate-y-1/2 w-10 h-10 bg-black/30 text-white rounded-full flex items-center justify-center hover:bg-black/50 transition-all" onclick="nextImage()">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
        <div class="md:w-1/2 p-8 md:p-16 flex flex-col justify-center overflow-y-auto bg-white dark:bg-slate-900">
            <div class="mb-10">
                <span class="inline-block px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-[0.2em] text-white mb-6 bg-primary" id="modal-category">Categoria</span>
                <h2 class="text-4xl md:text-5xl font-display font-bold dark:text-white leading-tight mb-8" id="modal-title">Título</h2>
                <div class="w-20 h-1.5 bg-primary rounded-full mb-10"></div>
                <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed font-light" id="modal-desc">Descrição.</p>
            </div>
            <div class="flex flex-wrap gap-4">
                <a class="px-8 py-4 bg-primary text-white rounded-full font-bold text-sm hover:bg-sky-400 transition-all flex items-center gap-2 shadow-xl shadow-primary/20" href="#contato">
                    Solicitar Info <span class="material-symbols-outlined text-base">info</span>
                </a>
                <button class="px-8 py-4 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white rounded-full font-bold text-sm hover:bg-slate-200 dark:hover:bg-slate-700 transition-all flex items-center gap-2" id="share-btn">
                    Compartilhar <span class="material-symbols-outlined text-base">share</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Calendar Section -->
    <section class="section-spacing bg-white dark:bg-slate-900" id="calendario">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col lg:flex-row gap-24 items-start">
                <div class="lg:w-1/3 lg:sticky lg:top-32">
                    <span class="text-primary font-bold tracking-[0.2em] uppercase text-sm mb-6 block">Agenda Cultural</span>
                    <h2 class="text-4xl sm:text-5xl font-display font-bold mb-8 dark:text-white leading-tight">Calendário de Eventos 2024/25</h2>
                    <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 leading-relaxed">Prepare sua visita para coincidir com as melhores festas e eventos tradicionais da nossa região.</p>
                    <button class="bg-slate-900 dark:bg-white dark:text-slate-900 text-white px-10 py-4 rounded-full font-bold flex items-center gap-3 hover:opacity-90 transition-all" onclick="window.print()">
                        Baixar Agenda PDF <span class="material-symbols-outlined">download</span>
                    </button>
                </div>
                <div class="lg:w-2/3 grid gap-6" id="events-container">
                    @foreach (var eventItem in upcomingEvents)
                    {
                        <div class="group flex flex-col md:flex-row gap-6 p-8 rounded-[2rem] bg-slate-50 dark:bg-slate-800 border border-slate-100 dark:border-slate-700 hover:border-primary transition-all">
                            <div class="flex-shrink-0 w-24 h-24 text-white rounded-2xl flex flex-col items-center justify-center font-bold shadow-lg"
                                 style="background-color: @(eventItem.EventType == "Gastronômico" ? "#0ea5e9" : eventItem.EventType == "Esportivo" ? "#10b981" : "#f97316")">
                                <span class="text-2xl">@eventItem.StartDate.ToString("MMM").ToUpper()</span>
                                <span class="text-lg">@eventItem.StartDate.Day</span>
                            </div>
                            <div>
                                <span class="text-primary font-bold text-xs uppercase tracking-widest mb-2 block">@eventItem.EventType</span>
                                <h4 class="text-2xl font-bold mb-3 dark:text-white">@eventItem.Title</h4>
                                <p class="text-slate-500 dark:text-slate-400 leading-relaxed">@eventItem.Description</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Hospitality Section -->
    <section class="section-spacing bg-slate-50 dark:bg-slate-950" id="guia">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-24">
                <span class="text-secondary font-bold tracking-[0.2em] uppercase text-sm mb-6 block">Hospitalidade</span>
                <h2 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold mb-8 dark:text-white">Guia de Experiências</h2>
                <div class="w-24 h-2 bg-secondary mx-auto rounded-full"></div>
            </div>
            <div class="grid lg:grid-cols-3 gap-10">
                @foreach (var type in new[] { "Hospedagem", "Gastronomia", "Atividades" })
                {
                    var items = ViewBag.GuideItemsByType[type] as List<GuideItem>;
                    <div class="bg-white dark:bg-slate-900 p-10 rounded-[3rem] shadow-sm border border-slate-200 dark:border-slate-800 flex flex-col h-full">
                        <div class="w-20 h-20 rounded-[1.5rem] flex items-center justify-center mb-8"
                             style="background-color: @(type == "Hospedagem" ? "#0ea5e9" : type == "Gastronomia" ? "#10b981" : "#f97316")20">
                            <span class="material-symbols-outlined text-5xl" style="color: @(type == "Hospedagem" ? "#0ea5e9" : type == "Gastronomia" ? "#10b981" : "#f97316")">
                                @(type == "Hospedagem" ? "hotel" : type == "Gastronomia" ? "restaurant" : "local_activity")
                            </span>
                        </div>
                        <h3 class="text-3xl font-bold mb-6 dark:text-white">@(type == "Hospedagem" ? "Onde Ficar" : type == "Gastronomia" ? "Onde Comer" : "O que Fazer")</h3>
                        <p class="text-slate-600 dark:text-slate-400 mb-8 text-lg leading-relaxed">
                            @(type == "Hospedagem" ? "Do luxo dos resorts à beira-rio ao aconchego das pousadas coloniais do centro." :
                              type == "Gastronomia" ? "A culinária caipira e os pratos típicos de rio são os protagonistas da nossa mesa." :
                              "Atividades para todas as idades, do descanso contemplativo à aventura náutica.")
                        </p>
                        <ul class="space-y-4 mb-10 flex-grow">
                            @foreach (var item in items?.Take(2) ?? new List<GuideItem>())
                            {
                                <li class="flex items-start gap-4 text-slate-700 dark:text-slate-300">
                                    <span class="material-symbols-outlined mt-1" style="color: @(type == "Hospedagem" ? "#0ea5e9" : type == "Gastronomia" ? "#10b981" : "#f97316")">check_circle</span>
                                    <div><strong class="block">@item.Name</strong> @item.Description</div>
                                </li>
                            }
                        </ul>
                        <a class="w-full py-4 text-center font-bold border-2 rounded-full transition-all"
                           style="border-color: @(type == "Hospedagem" ? "#0ea5e9" : type == "Gastronomia" ? "#10b981" : "#f97316"); color: @(type == "Hospedagem" ? "#0ea5e9" : type == "Gastronomia" ? "#10b981" : "#f97316")"
                           href="@Url.Action("Guide", "Home", new { type = type })"
                           onmouseover="this.style.backgroundColor='@(type == "Hospedagem" ? "#0ea5e9" : type == "Gastronomia" ? "#10b981" : "#f97316")'; this.style.color='white';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='@(type == "Hospedagem" ? "#0ea5e9" : type == "Gastronomia" ? "#10b981" : "#f97316")';">
                            @(type == "Hospedagem" ? "Ver Hotéis" : type == "Gastronomia" ? "Gastronomia" : "Explorar Tudo")
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="section-spacing bg-white dark:bg-slate-900" id="faq">
        <div class="max-w-4xl mx-auto px-6">
            <div class="text-center mb-24">
                <span class="text-primary font-bold tracking-[0.2em] uppercase text-sm mb-6 block">Suporte ao Turista</span>
                <h2 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold mb-8 dark:text-white">Dúvidas Frequentes</h2>
                <div class="w-24 h-2 bg-primary mx-auto rounded-full"></div>
            </div>
            <div class="space-y-6" id="faq-container">
                @foreach (var faq in ViewBag.FAQs)
                {
                    <details class="faq-card group bg-slate-50 dark:bg-slate-800 rounded-3xl border border-slate-100 dark:border-slate-700 overflow-hidden transition-all shadow-sm">
                        <summary class="p-8 flex items-center justify-between cursor-pointer focus:outline-none">
                            <h4 class="text-xl font-bold dark:text-white">@faq.Question</h4>
                            <span class="faq-icon material-symbols-outlined text-primary text-3xl transition-transform duration-300">expand_more</span>
                        </summary>
                        <div class="px-8 pb-8 text-slate-600 dark:text-slate-400 leading-relaxed text-lg">
                            @faq.Answer
                        </div>
                    </details>
                }
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 text-white pt-32 pb-16" id="contato">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-20 mb-24">
                <div class="lg:col-span-2">
                    <div class="flex items-center gap-3 mb-10">
                        <div class="w-12 h-12 bg-primary rounded-2xl flex items-center justify-center text-white">
                            <span class="material-symbols-outlined text-3xl">waves</span>
                        </div>
                        <span class="text-3xl font-extrabold tracking-tight">Barra <span class="text-primary">Bonita</span></span>
                    </div>
                    <p class="text-slate-400 text-lg max-w-lg mb-10 leading-relaxed">
                        Secretaria Municipal de Turismo e Cultura. Promovendo o desenvolvimento sustentável de Barra Bonita.
                    </p>
                    <div class="flex gap-6">
                        <a class="w-12 h-12 rounded-xl bg-slate-800 flex items-center justify-center hover:bg-primary transition-all" href="#"><span class="material-symbols-outlined">public</span></a>
                        <a class="w-12 h-12 rounded-xl bg-slate-800 flex items-center justify-center hover:bg-pink-600 transition-all" href="#"><span class="material-symbols-outlined">camera</span></a>
                    </div>
                </div>
                <div>
                    <h4 class="text-xl font-bold mb-10 flex items-center gap-3">Navegação <span class="w-8 h-[2px] bg-primary"></span></h4>
                    <ul class="space-y-4 text-slate-400">
                        <li><a class="hover:text-primary transition-colors" href="#hero">Início</a></li>
                        <li><a class="hover:text-primary transition-colors" href="#historia">História</a></li>
                        <li><a class="hover:text-primary transition-colors" href="#atracoes">Atrações</a></li>
                        <li><a class="hover:text-primary transition-colors" href="#calendario">Calendário</a></li>
                        <li><a class="hover:text-primary transition-colors" href="#guia">Guia</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-xl font-bold mb-10 flex items-center gap-3">Atendimento <span class="w-8 h-[2px] bg-primary"></span></h4>
                    <ul class="space-y-6 text-slate-400 text-sm">
                        <li class="flex items-start gap-4"><span class="material-symbols-outlined text-primary">phone</span> (14) 3604-4000</li>
                        <li class="flex items-start gap-4"><span class="material-symbols-outlined text-primary">mail</span> turismo@barrabonita.sp.gov.br</li>
                        <li class="flex items-start gap-4"><span class="material-symbols-outlined text-primary">location_on</span> Praça Waldemar Lopes Ferraz, s/n</li>
                    </ul>
                </div>
            </div>
            <div class="pt-16 border-t border-slate-800 text-center">
                <p class="text-slate-500 text-sm">© 2024 Estância Turística de Barra Bonita. Todos os direitos reservados.</p>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        const overlay = document.getElementById('attraction-overlay');
        const modal = document.getElementById('attraction-modal');
        const closeModalBtn = document.getElementById('close-modal');
        const modalImage = document.getElementById('modal-image');
        const modalTitle = document.getElementById('modal-title');
        const modalCategory = document.getElementById('modal-category');
        const modalDesc = document.getElementById('modal-desc');
        const modalDots = document.getElementById('modal-dots');

        let currentImages = [];
        let currentIdx = 0;

        function openModal(card) {
            const title = card.getAttribute('data-title');
            const category = card.getAttribute('data-category');
            const desc = card.getAttribute('data-desc');
            const images = JSON.parse(card.getAttribute('data-images'));

            modalTitle.innerText = title;
            modalCategory.innerText = category;
            modalDesc.innerText = desc;
            currentImages = images;
            currentIdx = 0;

            updateModalImage();
            createDots();

            overlay.classList.add('active');
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function createDots() {
            modalDots.innerHTML = '';
            currentImages.forEach((_, i) => {
                const dot = document.createElement('button');
                dot.className = `w-3 h-3 rounded-full transition-all ${i === currentIdx ? 'bg-primary scale-125' : 'bg-white/40'}`;
                dot.onclick = () => { currentIdx = i; updateModalImage(); };
                modalDots.appendChild(dot);
            });
        }

        function updateModalImage() {
            modalImage.style.opacity = '0';
            setTimeout(() => {
                modalImage.src = currentImages[currentIdx];
                modalImage.style.opacity = '1';
                const dots = modalDots.children;
                for (let i = 0; i < dots.length; i++) {
                    dots[i].className = `w-3 h-3 rounded-full transition-all ${i === currentIdx ? 'bg-primary scale-125' : 'bg-white/40'}`;
                }
            }, 200);
        }

        function nextImage() {
            currentIdx = (currentIdx + 1) % currentImages.length;
            updateModalImage();
        }

        function prevImage() {
            currentIdx = (currentIdx - 1 + currentImages.length) % currentImages.length;
            updateModalImage();
        }

        function closeModal() {
            overlay.classList.remove('active');
            modal.classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        // Attraction cards click handler
        document.querySelectorAll('.attraction-card').forEach(card => {
            card.onclick = (e) => {
                e.preventDefault();
                openModal(card);
            };
        });

        // Filter functionality
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const filter = this.getAttribute('data-filter');
                
                // Update active state
                document.querySelectorAll('.filter-btn').forEach(b => {
                    b.classList.remove('filter-btn-active');
                    b.classList.add('filter-btn-inactive');
                });
                this.classList.add('filter-btn-active');
                this.classList.remove('filter-btn-inactive');
                
                // Filter cards
                document.querySelectorAll('.attraction-card').forEach(card => {
                    if (filter === 'all' || card.getAttribute('data-category') === filter) {
                        card.style.display = 'block';
                        setTimeout(() => { card.style.opacity = '1'; }, 10);
                    } else {
                        card.style.opacity = '0';
                        setTimeout(() => { card.style.display = 'none'; }, 300);
                    }
                });
            });
        });

        closeModalBtn.onclick = closeModal;
        overlay.onclick = closeModal;

        // Share button
        document.getElementById('share-btn')?.addEventListener('click', () => {
            if (navigator.share) {
                navigator.share({
                    title: modalTitle.innerText,
                    text: modalDesc.innerText,
                    url: window.location.href
                });
            } else {
                alert('Compartilhe esta atração: ' + modalTitle.innerText);
            }
        });

        // Mobile menu toggle
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        if (menuToggle && mobileMenu) {
            menuToggle.addEventListener('change', function() {
                if (this.checked) {
                    mobileMenu.style.display = 'flex';
                } else {
                    mobileMenu.style.display = 'none';
                }
            });
        }

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                    // Close mobile menu if open
                    if (menuToggle?.checked) {
                        menuToggle.checked = false;
                        mobileMenu.style.display = 'none';
                    }
                }
            });
        });
    </script>
</body>
</html>