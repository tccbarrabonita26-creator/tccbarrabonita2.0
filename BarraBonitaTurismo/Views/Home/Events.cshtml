@model List<BarraBonitaTurismo.Models.Event>
@{
    ViewData["Title"] = "Calendário de Eventos";
}

<div class="container py-5">
    <h1 class="text-center mb-4">Calendário de Eventos</h1>
    
    <div class="row">
        @foreach (var eventItem in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    @if (eventItem.IsFeatured)
                    {
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-danger">Destaque</span>
                        </div>
                    }
                    <div class="row g-0">
                        <div class="col-md-4">
                            <img src="@eventItem.ImageUrl" class="img-fluid rounded-start h-100" style="object-fit: cover;" alt="@eventItem.Title">
                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <h5 class="card-title">@eventItem.Title</h5>
                                <p class="card-text">@eventItem.Description</p>
                                <p class="card-text">
                                    <small class="text-muted">
                                        <i class="fas fa-calendar"></i> 
                                        @eventItem.StartDate.ToString("dd/MM/yyyy")
                                        @if (eventItem.EndDate.HasValue)
                                        {
                                            <text> até @eventItem.EndDate.Value.ToString("dd/MM/yyyy")</text>
                                        }
                                    </small>
                                </p>
                                <p class="card-text">
                                    <small class="text-muted">
                                        <i class="fas fa-map-marker-alt"></i> @eventItem.Location
                                    </small>
                                </p>
                                <span class="badge bg-info">@eventItem.EventType</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>