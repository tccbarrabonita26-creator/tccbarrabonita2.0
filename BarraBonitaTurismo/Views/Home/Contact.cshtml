@model BarraBonitaTurismo.Models.ContactMessage
@{
    ViewData["Title"] = "Contato";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Barra Bonita</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;family=Playfair+Display:wght@700;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .bg-primary { background-color: #0ea5e9; }
        .text-primary { color: #0ea5e9; }
        .border-primary { border-color: #0ea5e9; }
        .hover\:bg-sky-400:hover { background-color: #38bdf8; }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-950">
    <div class="max-w-4xl mx-auto px-6 py-32">
        <div class="text-center mb-12">
            <h1 class="text-5xl font-display font-bold dark:text-white mb-4">Fale Conosco</h1>
            <div class="w-24 h-2 bg-primary mx-auto rounded-full"></div>
        </div>
        
        @if (TempData["Success"] != null)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-6 py-4 rounded-2xl mb-8">
                @TempData["Success"]
            </div>
        }
        
        <div class="bg-white dark:bg-slate-900 rounded-[2rem] shadow-xl overflow-hidden">
            <div class="grid md:grid-cols-2">
                <div class="bg-primary p-8 text-white">
                    <h3 class="text-2xl font-bold mb-6">Informações de Contato</h3>
                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <span class="material-symbols-outlined">location_on</span>
                            <div>
                                <strong>Endereço</strong><br>
                                Praça Waldemar Lopes Ferraz, s/n<br>
                                Barra Bonita - SP, 17340-000
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <span class="material-symbols-outlined">phone</span>
                            <div>
                                <strong>Telefone</strong><br>
                                (14) 3604-4000
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <span class="material-symbols-outlined">mail</span>
                            <div>
                                <strong>Email</strong><br>
                                turismo@barrabonita.sp.gov.br
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <span class="material-symbols-outlined">schedule</span>
                            <div>
                                <strong>Horário</strong><br>
                                Segunda a Sexta: 8h às 17h
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="p-8">
                    <form asp-action="Contact" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Name" class="block text-sm font-bold mb-2 dark:text-white">Nome *</label>
                            <input asp-for="Name" class="w-full px-4 py-2 rounded-xl border dark:bg-slate-800 dark:border-slate-700">
                            <span asp-validation-for="Name" class="text-red-600 text-sm"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Email" class="block text-sm font-bold mb-2 dark:text-white">Email *</label>
                            <input asp-for="Email" type="email" class="w-full px-4 py-2 rounded-xl border dark:bg-slate-800 dark:border-slate-700">
                            <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Subject" class="block text-sm font-bold mb-2 dark:text-white">Assunto *</label>
                            <input asp-for="Subject" class="w-full px-4 py-2 rounded-xl border dark:bg-slate-800 dark:border-slate-700">
                            <span asp-validation-for="Subject" class="text-red-600 text-sm"></span>
                        </div>
                        
                        <div class="mb-6">
                            <label asp-for="Message" class="block text-sm font-bold mb-2 dark:text-white">Mensagem *</label>
                            <textarea asp-for="Message" rows="5" class="w-full px-4 py-2 rounded-xl border dark:bg-slate-800 dark:border-slate-700"></textarea>
                            <span asp-validation-for="Message" class="text-red-600 text-sm"></span>
                        </div>
                        
                        <button type="submit" class="w-full bg-primary text-white py-3 rounded-xl font-bold hover:bg-sky-400 transition-all">
                            Enviar Mensagem
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>